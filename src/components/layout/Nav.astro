---
import type { Locale } from '../../i18n/utils';
import { localizePath } from '../../i18n/utils';
import { useTranslations } from '../../i18n/ui';
import { site } from '../../config/site';

interface Props { lang: Locale; }
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<nav class="pf-nav">
  <a href="#top" class="pf-nav__logo" aria-label={site.initials}>
    <span class="pf-nav__logo-box">{site.initials}</span>
  </a>

  <div class="pf-nav__right">
    <div class="pf-nav__links" id="pf-nav-menu">
      <a href="#trabajo" class="pf-nav__link" data-nav-link>{t('nav.work')}</a>
      <a href="#stack"   class="pf-nav__link" data-nav-link>{t('nav.stack')}</a>
      <a href="#contacto" class="pf-nav__link" data-nav-link>{t('nav.contact')}</a>
    </div>

    <div class="pf-nav__lang-picker" role="group" aria-label="Language">
      <a
        href={localizePath('/', 'es')}
        class="pf-nav__lang-btn"
        aria-current={lang === 'es' ? 'true' : undefined}
        hreflang="es"
      >ES</a>
      <a
        href={localizePath('/', 'en')}
        class="pf-nav__lang-btn pf-nav__lang-btn--sep"
        aria-current={lang === 'en' ? 'true' : undefined}
        hreflang="en"
      >EN</a>
    </div>

    <button
      id="pf-theme-toggle"
      class="pf-nav__theme-btn"
      aria-label="Toggle colour theme"
      type="button"
    >◐</button>

    <button
      id="pf-nav-burger"
      class="pf-nav__burger"
      aria-label="Menú"
      aria-expanded="false"
      aria-controls="pf-nav-menu"
      type="button"
    >
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<style>
  .pf-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px clamp(20px, 5vw, 64px);
    backdrop-filter: blur(10px);
    background: linear-gradient(180deg, rgba(8, 8, 11, 0.72), transparent);
  }

  .pf-nav__logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--text);
  }

  .pf-nav__logo-box {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border: 1px solid var(--border);
    border-radius: 10px;
    font-family: 'JetBrains Mono', monospace;
    font-weight: 500;
    letter-spacing: 0.5px;
    background: var(--accent-soft);
  }

  .pf-nav__right {
    display: flex;
    align-items: center;
    gap: clamp(14px, 2vw, 24px);
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    letter-spacing: 0.3px;
  }

  .pf-nav__links {
    display: flex;
    align-items: center;
    gap: clamp(16px, 3vw, 38px);
  }

  .pf-nav__link {
    color: var(--muted);
    text-decoration: none;
    transition: color 0.25s;
  }

  .pf-nav__link:hover {
    color: var(--text);
  }

  /* Hamburger — hidden on desktop, shown on small screens. */
  .pf-nav__burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    width: 34px;
    height: 34px;
    padding: 0 8px;
    border: 1px solid var(--border);
    border-radius: 9px;
    background: transparent;
    cursor: pointer;
  }

  .pf-nav__burger span {
    display: block;
    height: 2px;
    width: 100%;
    background: var(--text);
    border-radius: 2px;
    transition: transform 0.25s ease, opacity 0.2s ease;
  }

  .pf-nav[data-open='true'] .pf-nav__burger span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }

  .pf-nav[data-open='true'] .pf-nav__burger span:nth-child(2) {
    opacity: 0;
  }

  .pf-nav[data-open='true'] .pf-nav__burger span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  .pf-nav__lang-picker {
    display: flex;
    align-items: center;
    border: 1px solid var(--border);
    border-radius: 9px;
    overflow: hidden;
  }

  .pf-nav__lang-btn {
    padding: 7px 9px;
    background: transparent;
    border: 0;
    color: var(--muted);
    cursor: pointer;
    font-family: inherit;
    font-size: 12px;
    letter-spacing: 0.5px;
    transition: background 0.25s, color 0.25s;
    text-decoration: none;
  }

  .pf-nav__lang-btn--sep {
    border-left: 1px solid var(--border);
  }

  .pf-nav__lang-btn[aria-current='true'] {
    background: var(--accent-soft);
    color: var(--text);
  }

  .pf-nav__lang-btn:hover:not([aria-current='true']) {
    background: var(--surface);
    color: var(--text);
  }

  .pf-nav__theme-btn {
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    border: 1px solid var(--border);
    border-radius: 9px;
    background: transparent;
    color: var(--text);
    cursor: pointer;
    font-size: 14px;
    transition: background 0.25s;
  }

  .pf-nav__theme-btn:hover {
    background: var(--surface);
  }

  /* ---- Mobile: collapse the section links into a dropdown panel ---- */
  @media (max-width: 768px) {
    .pf-nav {
      padding: 14px clamp(20px, 5vw, 64px);
    }

    .pf-nav__burger {
      display: flex;
    }

    .pf-nav__links {
      position: absolute;
      top: calc(100% + 8px);
      left: clamp(20px, 5vw, 64px);
      right: clamp(20px, 5vw, 64px);
      flex-direction: column;
      align-items: stretch;
      gap: 2px;
      padding: 10px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 14px;
      box-shadow: 0 24px 60px -24px rgba(0, 0, 0, 0.65);
      opacity: 0;
      transform: translateY(-8px);
      pointer-events: none;
      transition: opacity 0.25s ease, transform 0.25s ease;
    }

    .pf-nav[data-open='true'] .pf-nav__links {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }

    .pf-nav__link {
      padding: 12px 14px;
      border-radius: 9px;
      font-size: 14px;
      color: var(--text);
    }

    .pf-nav__link:hover,
    .pf-nav__link[data-active='1'] {
      background: var(--bg2);
    }
  }
</style>
