---
import { useTranslations } from '../../i18n/ui';
import type { Locale } from '../../i18n/utils';
import { site } from '../../config/site';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="contacto" class="contact">
  <div class="contact-inner">
    <div data-reveal class="contact-label">{t('contact.label')}</div>
    <h2
      data-reveal
      data-reveal-delay="100"
      class="contact-title"
      set:html={t('contact.title')}
    />
    <p data-reveal data-reveal-delay="200" class="contact-body">{t('contact.body')}</p>
    <div data-reveal data-reveal-delay="300" class="contact-actions">
      <a href={`mailto:${site.email}`} data-magnetic class="contact-btn-email">
        {site.email}
      </a>
      <a
        href={site.github}
        target="_blank"
        rel="noopener"
        data-magnetic
        class="contact-btn-github"
      >
        GitHub ↗
      </a>
    </div>
  </div>
</section>

<style>
  .contact {
    position: relative;
    z-index: 2;
    border-top: 1px solid var(--border);
    background: var(--bg2);
  }

  .contact-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: clamp(80px, 16vh, 180px) clamp(20px, 5vw, 64px);
    text-align: center;
  }

  .contact-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    letter-spacing: 2px;
    color: var(--accent2);
    margin-bottom: 26px;
  }

  .contact-title {
    margin: 0;
    font-size: clamp(40px, 8vw, 110px);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 0.95;
  }

  .contact-body {
    max-width: 540px;
    margin: 28px auto 0;
    color: var(--muted);
    font-size: clamp(17px, 2vw, 20px);
    line-height: 1.5;
    text-wrap: pretty;
  }

  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    justify-content: center;
    margin-top: 42px;
  }

  .contact-btn-email {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 30px;
    border-radius: 12px;
    background: var(--accent);
    color: #fff;
    text-decoration: none;
    font-weight: 600;
    font-size: 16px;
    box-shadow: 0 8px 34px -8px var(--accent);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .contact-btn-github {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 30px;
    border-radius: 12px;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text);
    text-decoration: none;
    font-weight: 500;
    font-size: 16px;
    transition:
      transform 0.3s cubic-bezier(0.16, 1, 0.3, 1),
      border-color 0.3s;
  }
</style>
