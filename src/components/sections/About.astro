---
import { useTranslations } from '../../i18n/ui';
import type { Locale } from '../../i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="about">
  <div data-reveal class="about-label">{t('about.label')}</div>
  <p data-reveal data-reveal-delay="120" class="about-body" set:html={t('about.body')} />
</section>

<style>
  .about {
    position: relative;
    z-index: 2;
    max-width: 1100px;
    margin: 0 auto;
    padding: clamp(80px, 14vh, 160px) clamp(20px, 5vw, 64px);
  }

  .about-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    letter-spacing: 2px;
    color: var(--accent2);
    margin-bottom: 30px;
  }

  .about-body {
    margin: 0;
    font-size: clamp(26px, 4vw, 52px);
    line-height: 1.28;
    font-weight: 500;
    letter-spacing: -0.02em;
    text-wrap: balance;
  }
</style>
